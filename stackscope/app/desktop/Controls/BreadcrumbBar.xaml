<UserControl x:Class="StackScope.Desktop.Controls.BreadcrumbBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ItemsControl x:Name="Chips">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" IsItemsHost="True"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <StackPanel Orientation="Horizontal" Margin="0,0,4,0">
                    <Button Content="{Binding Label}"
                            Padding="8,2" Margin="0"
                            Background="{StaticResource Brush.Surface.Elevated}"
                            BorderBrush="{StaticResource Brush.Border.Subtle}"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            FontFamily="{StaticResource Font.Mono}"
                            Tag="{Binding}"
                            Click="OnChipClick"
                            AutomationProperties.Name="{Binding AutomationName}"/>
                    <TextBlock Text="›" Style="{StaticResource Text.Muted}"
                               VerticalAlignment="Center" Margin="4,0"
                               Visibility="{Binding ShowSeparator,
                                    Converter={StaticResource BoolVis}}"/>
                </StackPanel>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
