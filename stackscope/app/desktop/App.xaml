<Application x:Class="StackScope.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:StackScope.Desktop.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Dark.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:ListRankConverter x:Key="Rank"/>
            <conv:NsToMillisConverter x:Key="NsMs"/>
            <conv:KindToBrushConverter x:Key="KindBrush"/>
            <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
            <conv:InverseBoolConverter x:Key="InverseBool"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
