<UserControl x:Class="StackScope.Desktop.Views.EventListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:StackScope.Desktop.ViewModels"
             xmlns:conv="clr-namespace:StackScope.Desktop.Converters"
             mc:Ignorable="d" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="400" d:DesignWidth="800"
             Background="{StaticResource Brush.Surface.Panel}">

    <UserControl.Resources>
        <conv:NsToMillisConverter x:Key="NsMs"/>
        <conv:KindToBrushConverter x:Key="KindBrush"/>
    </UserControl.Resources>

    <DockPanel LastChildFill="True">
        <!-- Filter chrome -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Brush.Surface.Elevated}"
                BorderBrush="{StaticResource Brush.Border.Subtle}" BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Events:" Style="{StaticResource Text.Muted}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TotalCount, StringFormat={}{0:N0}}"
                           Style="{StaticResource Text.Body}"
                           Margin="8,0,16,0" VerticalAlignment="Center"
                           x:Name="TotalCountText"
                           AutomationProperties.Name="Total matching event count"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}"
                        AutomationProperties.Name="Refresh event list"
                        x:Name="RefreshBtn"/>
                <TextBlock Text="Page" Style="{StaticResource Text.Muted}"
                           VerticalAlignment="Center" Margin="24,0,4,0"/>
                <TextBox Width="48" Text="{Binding Page, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         AutomationProperties.Name="Page number"/>
                <TextBlock Text="Size" Style="{StaticResource Text.Muted}"
                           VerticalAlignment="Center" Margin="12,0,4,0"/>
                <TextBox Width="64" Text="{Binding PageSize, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="Page size"/>
                <ProgressBar IsIndeterminate="{Binding IsLoading}" Width="80" Height="4"
                             Margin="16,0" VerticalAlignment="Center"
                             Foreground="{StaticResource Brush.Accent.Cyan}"
                             Background="Transparent"/>
            </StackPanel>
        </Border>

        <!-- Event grid -->
        <ListView ItemsSource="{Binding Events}"
                  SelectedValue="{Binding SelectedEvent, Mode=OneWayToSource}"
                  AutomationProperties.Name="Event list"
                  x:Name="EventGrid"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID" Width="80"
                                    DisplayMemberBinding="{Binding EventId}"/>
                    <GridViewColumn Header="Kind" Width="128">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="6" Height="14"
                                               Fill="{Binding Kind, Converter={StaticResource KindBrush}}"
                                               Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Kind}" Style="{StaticResource Text.Mono}"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Token" Width="60"
                                    DisplayMemberBinding="{Binding TokenIndex}"/>
                    <GridViewColumn Header="Layer" Width="60"
                                    DisplayMemberBinding="{Binding LayerIndex}"/>
                    <GridViewColumn Header="Head" Width="60"
                                    DisplayMemberBinding="{Binding HeadIndex}"/>
                    <GridViewColumn Header="ts (ms)" Width="100"
                                    DisplayMemberBinding="{Binding TimestampNs,
                                        Converter={StaticResource NsMs}}"/>
                    <GridViewColumn Header="Stream" Width="60"
                                    DisplayMemberBinding="{Binding StreamId}"/>
                    <GridViewColumn Header="Dev" Width="50"
                                    DisplayMemberBinding="{Binding DeviceId}"/>
                </GridView>
            </ListView.View>
            <ListView.InputBindings>
                <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
            </ListView.InputBindings>
        </ListView>
    </DockPanel>
</UserControl>
