<UserControl x:Class="StackScope.Desktop.Views.QuantizationDiffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:StackScope.Desktop.Behaviors"
             Background="{StaticResource Brush.Surface.Panel}">
  <ScrollViewer>
    <StackPanel Margin="16">
      <TextBlock Text="Quantization Diff" Style="{StaticResource Text.Header}"
                 FontSize="{StaticResource Type.Display}" Margin="0,0,0,12"/>
      <TextBlock Style="{StaticResource Text.Muted}" TextWrapping="Wrap"
                 Text="Run the same prompt at two numeric precisions (e.g. f16 vs q4_k_m). Reports the first divergent sampled token, the first layer past a sigma threshold, and per-layer distribution shift."/>

      <Grid Margin="0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Reference tx" Style="{StaticResource Text.Muted}" VerticalAlignment="Center" Margin="0,0,8,4"/>
        <TextBox   Grid.Row="0" Grid.Column="1" Margin="0,0,8,4" Text="{Binding ReferenceTx, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Grid.Row="0" Grid.Column="2" Text="Ref quant"    Style="{StaticResource Text.Muted}" VerticalAlignment="Center" Margin="8,0,8,4"/>
        <TextBox   Grid.Row="0" Grid.Column="3" Margin="0,0,0,4" Text="{Binding ReferenceQuant, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Candidate tx" Style="{StaticResource Text.Muted}" VerticalAlignment="Center" Margin="0,0,8,4"/>
        <TextBox   Grid.Row="1" Grid.Column="1" Margin="0,0,8,4" Text="{Binding CandidateTx, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Grid.Row="1" Grid.Column="2" Text="Cand quant"   Style="{StaticResource Text.Muted}" VerticalAlignment="Center" Margin="8,0,8,4"/>
        <TextBox   Grid.Row="1" Grid.Column="3" Margin="0,0,0,4" Text="{Binding CandidateQuant, UpdateSourceTrigger=PropertyChanged}"/>
      </Grid>

      <StackPanel Orientation="Horizontal" Margin="0,4">
        <Button Content="Compare" Command="{Binding CompareCommand}" MinWidth="120"
                AutomationProperties.Name="Run quantization diff"/>
        <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Muted}"
                   Margin="16,0,0,0" VerticalAlignment="Center"/>
      </StackPanel>

      <StackPanel Orientation="Horizontal" Margin="0,10">
        <TextBlock Style="{StaticResource Text.Muted}"><Run Text="First divergent token: "/><Run Text="{Binding FirstDivergentToken}"/></TextBlock>
        <TextBlock Style="{StaticResource Text.Muted}" Margin="20,0,0,0"><Run Text="Layer: "/><Run Text="{Binding FirstDivergentLayer}"/></TextBlock>
        <TextBlock Style="{StaticResource Text.Muted}" Margin="20,0,0,0"><Run Text="Total energy Δ: "/><Run Text="{Binding TotalEnergyDelta, StringFormat=F3}"/></TextBlock>
      </StackPanel>

      <ListView beh:SelectionDrives.IsEnabled="True" ItemsSource="{Binding Rows}" Height="360" Margin="0,8"
                AutomationProperties.Name="Per-layer quantization shift">
        <ListView.View>
          <GridView>
            <GridViewColumn Header="Layer"        Width="60"  DisplayMemberBinding="{Binding Layer}"/>
            <GridViewColumn Header="Sigma shift"  Width="140" DisplayMemberBinding="{Binding SigmaShift, StringFormat=F4}"/>
            <GridViewColumn Header="Cosine sim"   Width="140" DisplayMemberBinding="{Binding CosineSimilarity, StringFormat=F4}"/>
          </GridView>
        </ListView.View>
      </ListView>
    </StackPanel>
  </ScrollViewer>
</UserControl>
