<UserControl x:Class="StackScope.Desktop.Views.ProjectTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Surface.Panel}">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="8">
            <TextBlock Text="Project" Style="{StaticResource Text.Header}"/>
            <TextBlock Text="{Binding ProjectRoot}" Style="{StaticResource Text.Mono}"
                       TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
        </StackPanel>
        <TreeView x:Name="Tree"
                  ItemsSource="{Binding Nodes}"
                  Background="{StaticResource Brush.Surface.Panel}"
                  BorderBrush="{StaticResource Brush.Border.Subtle}"
                  Foreground="{StaticResource Brush.Text.Primary}"
                  AutomationProperties.Name="Project tree">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Icon}" Style="{StaticResource Text.Muted}"
                                   Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding Label}" Style="{StaticResource Text.Body}"/>
                        <TextBlock Text="{Binding Detail}" Style="{StaticResource Text.Muted}"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </DockPanel>
</UserControl>
