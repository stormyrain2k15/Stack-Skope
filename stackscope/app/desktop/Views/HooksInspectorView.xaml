<UserControl x:Class="StackScope.Desktop.Views.HooksInspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Surface.Panel}">
  <ScrollViewer>
    <StackPanel Margin="16">
      <TextBlock Text="Hooks Inspector" Style="{StaticResource Text.Header}"
                 FontSize="{StaticResource Type.Display}" Margin="0,0,0,12"
                 AutomationProperties.Name="Hooks inspector heading"/>
      <TextBlock Style="{StaticResource Text.Muted}" TextWrapping="Wrap"
                 Text="One-click classification of every module in a model — which ones StackScope will treat as transformer blocks, attention projections, or activations. The single fastest way to diagnose hook-detection bugs. No terminal required."/>

      <StackPanel Orientation="Horizontal" Margin="0,12,0,6">
        <TextBlock Text="Model" Style="{StaticResource Text.Muted}" VerticalAlignment="Center"/>
        <ComboBox Width="140" Margin="8,0"
                  IsEditable="True"
                  ItemsSource="{Binding Presets}"
                  Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}"
                  AutomationProperties.Name="Model preset selector"/>
        <TextBlock Style="{StaticResource Text.Muted}" VerticalAlignment="Center"
                   Text="(or type hf:&lt;checkpoint-id&gt; for a real HF architecture)"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
        <Button Content="Inspect" Command="{Binding InspectCommand}"
                MinWidth="96" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                AutomationProperties.Name="Run hooks inspection"/>
        <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Muted}"
                   Margin="16,0,0,0" VerticalAlignment="Center"/>
      </StackPanel>

      <Border BorderThickness="1" BorderBrush="{StaticResource Brush.Border}"
              Padding="8" Background="{StaticResource Brush.Surface.Elevated}">
        <TextBox Text="{Binding Output, Mode=OneWay}" IsReadOnly="True"
                 FontFamily="Consolas, Cascadia Mono, Courier New"
                 MinHeight="360" VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 AutomationProperties.Name="Hooks classification output"/>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
