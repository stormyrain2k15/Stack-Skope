<UserControl x:Class="StackScope.Desktop.Views.LiveTailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Surface.Panel}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,10">
      <TextBlock Text="Live Tail" Style="{StaticResource Text.Header}"
                 FontSize="{StaticResource Type.Display}"/>
      <TextBlock Style="{StaticResource Text.Muted}" TextWrapping="Wrap"
                 Text="Stream new events from a running capture directory. Great for watching a long training loop or generation session without opening the full timeline."/>
    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
      <TextBlock Text="Capture" Style="{StaticResource Text.Muted}" VerticalAlignment="Center"/>
      <TextBox Width="360" Margin="6,0"
               Text="{Binding CapturePath, UpdateSourceTrigger=PropertyChanged}"
               AutomationProperties.Name="Capture path"/>
      <TextBlock Text="Grep" Style="{StaticResource Text.Muted}" VerticalAlignment="Center" Margin="12,0,0,0"/>
      <TextBox Width="140" Margin="6,0" Text="{Binding Grep, UpdateSourceTrigger=PropertyChanged}"
               AutomationProperties.Name="Grep filter"/>
      <TextBlock Text="Kinds" Style="{StaticResource Text.Muted}" VerticalAlignment="Center" Margin="12,0,0,0"/>
      <TextBox Width="200" Margin="6,0" Text="{Binding Kind, UpdateSourceTrigger=PropertyChanged}"
               AutomationProperties.Name="Kind filter"/>
      <Button Content="Start" Command="{Binding StartCommand}" MinWidth="72" Margin="12,0,0,0"
              AutomationProperties.Name="Start tailing"/>
      <Button Content="Stop"  Command="{Binding StopCommand}"  MinWidth="72" Margin="6,0"
              AutomationProperties.Name="Stop tailing"/>
      <Button Content="Clear" Command="{Binding ClearCommand}" MinWidth="72"
              AutomationProperties.Name="Clear tail"/>
    </StackPanel>

    <Border Grid.Row="2" BorderThickness="1" BorderBrush="{StaticResource Brush.Border}"
            Background="{StaticResource Brush.Surface.Elevated}">
      <ListBox ItemsSource="{Binding Lines}" FontFamily="Consolas"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               ScrollViewer.HorizontalScrollBarVisibility="Auto"
               AutomationProperties.Name="Live tail output"/>
    </Border>
  </Grid>
</UserControl>
