<UserControl x:Class="StackScope.Desktop.Views.AblationPresetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Surface.Panel}">
  <DockPanel Margin="12" LastChildFill="True">
    <TextBlock DockPanel.Dock="Top" Text="Ablation Preset Library"
               Style="{StaticResource Text.Header}"
               FontSize="{StaticResource Type.Display}" Margin="0,0,0,4"/>
    <TextBlock DockPanel.Dock="Top" Style="{StaticResource Text.Muted}"
               TextWrapping="Wrap" Margin="0,0,0,10"
               Text="Save the current ablation range + sigma + cross-prompt list under a name. Loading a preset seeds both Analysis Lab (capture) and Ablation Sweep (heatmap) controls."/>
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
      <TextBlock Text="Name" Style="{StaticResource Text.Muted}"
                 VerticalAlignment="Center" Width="52"/>
      <TextBox   Width="260" Margin="6,0"
                 Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                 AutomationProperties.Name="Preset name"/>
      <Button    Content="Save current" Command="{Binding SaveCurrentCommand}"
                 Padding="12,4" Margin="8,0"
                 AutomationProperties.Name="Save current ablation as preset"/>
      <Button    Content="Load"         Command="{Binding LoadSelectedCommand}"
                 Padding="12,4"
                 AutomationProperties.Name="Load selected preset"/>
      <Button    Content="Delete"       Command="{Binding DeleteSelectedCommand}"
                 Padding="12,4" Margin="8,0"
                 AutomationProperties.Name="Delete selected preset"/>
      <Button    Content="Refresh"      Command="{Binding RefreshCommand}"
                 Padding="12,4"
                 AutomationProperties.Name="Refresh preset list"/>
      <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Muted}"
                 VerticalAlignment="Center" Margin="16,0,0,0"
                 TextTrimming="CharacterEllipsis" MaxWidth="480"/>
    </StackPanel>

    <ListView ItemsSource="{Binding Presets}"
              SelectedItem="{Binding Selected}"
              AutomationProperties.Name="Ablation presets list">
      <ListView.View>
        <GridView>
          <GridViewColumn Header="#"       Width="50"  DisplayMemberBinding="{Binding Id}"/>
          <GridViewColumn Header="Name"    Width="220" DisplayMemberBinding="{Binding Name}"/>
          <GridViewColumn Header="Layers"  Width="90">
            <GridViewColumn.CellTemplate>
              <DataTemplate>
                <TextBlock>
                  <Run Text="{Binding LayerStart}"/><Run Text=" … "/><Run Text="{Binding LayerEnd}"/>
                </TextBlock>
              </DataTemplate>
            </GridViewColumn.CellTemplate>
          </GridViewColumn>
          <GridViewColumn Header="Heads"   Width="90">
            <GridViewColumn.CellTemplate>
              <DataTemplate>
                <TextBlock>
                  <Run Text="{Binding HeadStart}"/><Run Text=" … "/><Run Text="{Binding HeadEnd}"/>
                </TextBlock>
              </DataTemplate>
            </GridViewColumn.CellTemplate>
          </GridViewColumn>
          <GridViewColumn Header="σ"       Width="60">
            <GridViewColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Style="{StaticResource Text.Mono}"
                           Text="{Binding SigmaThreshold, StringFormat={}{0:F2}}"/>
              </DataTemplate>
            </GridViewColumn.CellTemplate>
          </GridViewColumn>
          <GridViewColumn Header="Extra prompts" Width="360"
                          DisplayMemberBinding="{Binding Prompt}"/>
        </GridView>
      </ListView.View>
    </ListView>
  </DockPanel>
</UserControl>
