<UserControl x:Class="StackScope.Desktop.Views.AttributionGraphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:StackScope.Desktop.Behaviors"
             Background="{StaticResource Brush.Surface.Panel}">
  <ScrollViewer>
    <StackPanel Margin="16">
      <TextBlock Text="Attribution Graph" Style="{StaticResource Text.Header}"
                 FontSize="{StaticResource Type.Display}" Margin="0,0,0,12"/>
      <TextBlock Style="{StaticResource Text.Muted}" TextWrapping="Wrap"
                 Text="Weighted causal graph rooted at the output logits for a chosen token. Nodes are events (attention scores, activations, logits). Edge weight approximates contribution: attention max-prob, activation energy, logit top-1."/>

      <StackPanel Orientation="Horizontal" Margin="0,12">
        <TextBlock Text="Transaction" Style="{StaticResource Text.Muted}" VerticalAlignment="Center"/>
        <TextBox Width="240" Margin="6,0" Text="{Binding TransactionId, UpdateSourceTrigger=PropertyChanged}"
                 AutomationProperties.Name="Attribution transaction id"/>
        <TextBlock Text="Token" Style="{StaticResource Text.Muted}" VerticalAlignment="Center" Margin="12,0,0,0"/>
        <TextBox Width="60" Margin="6,0" Text="{Binding TargetToken, UpdateSourceTrigger=PropertyChanged}"
                 AutomationProperties.Name="Attribution target token"/>
        <TextBlock Text="Max/layer" Style="{StaticResource Text.Muted}" VerticalAlignment="Center" Margin="12,0,0,0"/>
        <TextBox Width="52" Margin="6,0" Text="{Binding MaxPerLayer, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="Max layers" Style="{StaticResource Text.Muted}" VerticalAlignment="Center" Margin="12,0,0,0"/>
        <TextBox Width="52" Margin="6,0" Text="{Binding MaxLayers, UpdateSourceTrigger=PropertyChanged}"/>
        <Button Content="Build" Command="{Binding BuildCommand}" MinWidth="96" Margin="12,0,0,0"
                AutomationProperties.Name="Build attribution graph"/>
        <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Muted}" Margin="16,0,0,0" VerticalAlignment="Center"/>
      </StackPanel>

      <TextBlock Text="Nodes" Style="{StaticResource Text.Header}" Margin="0,12,0,4"/>
      <ListView beh:SelectionDrives.IsEnabled="True" ItemsSource="{Binding Nodes}" Height="220"
                x:Name="NodeList"
                SelectionChanged="OnNodeSelected"
                AutomationProperties.Name="Attribution nodes">
        <ListView.ItemContainerStyle>
          <Style TargetType="ListViewItem">
            <Setter Property="ToolTip">
              <Setter.Value>
                <StackPanel>
                  <TextBlock FontWeight="Bold">
                    <Run Text="Event "/><Run Text="{Binding EventId}"/>
                  </TextBlock>
                  <TextBlock>
                    <Run Text="Layer "/><Run Text="{Binding Layer}"/>
                    <Run Text="  Head "/><Run Text="{Binding Head}"/>
                    <Run Text="  "/><Run Text="{Binding Kind}"/>
                  </TextBlock>
                  <TextBlock Text="{Binding Label}"/>
                </StackPanel>
              </Setter.Value>
            </Setter>
          </Style>
        </ListView.ItemContainerStyle>
        <ListView.View>
          <GridView>
            <GridViewColumn Header="Event"  Width="80"  DisplayMemberBinding="{Binding EventId}"/>
            <GridViewColumn Header="Layer"  Width="60"  DisplayMemberBinding="{Binding Layer}"/>
            <GridViewColumn Header="Head"   Width="60"  DisplayMemberBinding="{Binding Head}"/>
            <GridViewColumn Header="Kind"   Width="140" DisplayMemberBinding="{Binding Kind}"/>
            <GridViewColumn Header="Label"  Width="360" DisplayMemberBinding="{Binding Label}"/>
          </GridView>
        </ListView.View>
      </ListView>

      <TextBlock Text="Edges" Style="{StaticResource Text.Header}" Margin="0,12,0,4"/>
      <ListView beh:SelectionDrives.IsEnabled="True" ItemsSource="{Binding Edges}" Height="200"
                AutomationProperties.Name="Attribution edges">
        <ListView.View>
          <GridView>
            <GridViewColumn Header="From"   Width="80"  DisplayMemberBinding="{Binding From}"/>
            <GridViewColumn Header="To"     Width="80"  DisplayMemberBinding="{Binding To}"/>
            <GridViewColumn Header="Weight" Width="100" DisplayMemberBinding="{Binding Weight, StringFormat=F4}"/>
            <GridViewColumn Header="Reason" Width="360" DisplayMemberBinding="{Binding Reason}"/>
          </GridView>
        </ListView.View>
      </ListView>
    </StackPanel>
  </ScrollViewer>
</UserControl>
