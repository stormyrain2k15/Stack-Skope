<UserControl x:Class="StackScope.Desktop.Views.DeterminismAuditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:StackScope.Desktop.Behaviors"
             Background="{StaticResource Brush.Surface.Panel}">
  <ScrollViewer>
    <StackPanel Margin="16">
      <TextBlock Text="Determinism Auditor" Style="{StaticResource Text.Header}"
                 FontSize="{StaticResource Type.Display}" Margin="0,0,0,12"/>
      <TextBlock Style="{StaticResource Text.Muted}" TextWrapping="Wrap"
                 Text="Two runs of the same input. Reports which kernel first introduced non-determinism, with a content hash of the mismatched event. Great for hunting flaky reductions or float atomics."/>

      <TextBlock Text="Run A (baseline)"  Style="{StaticResource Text.Muted}" Margin="0,12,0,4"/>
      <TextBox Text="{Binding RunA, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Determinism run A"/>
      <TextBlock Text="Run B (candidate)" Style="{StaticResource Text.Muted}" Margin="0,10,0,4"/>
      <TextBox Text="{Binding RunB, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Determinism run B"/>

      <StackPanel Orientation="Horizontal" Margin="0,12">
        <Button Content="Audit" Command="{Binding AuditCommand}" MinWidth="96"
                AutomationProperties.Name="Run determinism audit"/>
        <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Muted}" Margin="16,0" VerticalAlignment="Center"/>
      </StackPanel>

      <ListView beh:SelectionDrives.IsEnabled="True" ItemsSource="{Binding Findings}" Height="360"
                AutomationProperties.Name="Determinism findings">
        <ListView.View>
          <GridView>
            <GridViewColumn Header="Layer"     Width="60"  DisplayMemberBinding="{Binding LayerIndex}"/>
            <GridViewColumn Header="Kind"      Width="120" DisplayMemberBinding="{Binding Kind}"/>
            <GridViewColumn Header="Corr id"   Width="120" DisplayMemberBinding="{Binding CorrelationId}"/>
            <GridViewColumn Header="Marker"    Width="180" DisplayMemberBinding="{Binding MarkerName}"/>
            <GridViewColumn Header="Hash A"    Width="120" DisplayMemberBinding="{Binding HashA}"/>
            <GridViewColumn Header="Hash B"    Width="120" DisplayMemberBinding="{Binding HashB}"/>
          </GridView>
        </ListView.View>
      </ListView>
    </StackPanel>
  </ScrollViewer>
</UserControl>
