<UserControl x:Class="StackScope.Desktop.Views.BugReportExporterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Surface.Panel}">
  <ScrollViewer>
    <StackPanel Margin="16">
      <TextBlock Text="Send Bug Report" Style="{StaticResource Text.Header}"
                 FontSize="{StaticResource Type.Display}" Margin="0,0,0,12"/>
      <TextBlock Style="{StaticResource Text.Muted}" TextWrapping="Wrap"
                 Text="One click. StackScope collects the current capture, snapshots your software environment (Python + torch + CUDA/ROCm/Vulkan + drivers), and packs it all into a .stackscope zip you can attach to a GitHub issue or share with support."/>

      <TextBlock Text="Capture directory (optional)" Style="{StaticResource Text.Muted}" Margin="0,12,0,4"/>
      <TextBox Text="{Binding CaptureDir, UpdateSourceTrigger=PropertyChanged}"
               AutomationProperties.Name="Bug report capture directory"/>

      <TextBlock Text="What happened?" Style="{StaticResource Text.Muted}" Margin="0,10,0,4"/>
      <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
               AcceptsReturn="True" MinHeight="120"
               AutomationProperties.Name="Bug description"/>

      <TextBlock Text="Output path (optional — defaults to Desktop)" Style="{StaticResource Text.Muted}" Margin="0,10,0,4"/>
      <TextBox Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
               AutomationProperties.Name="Bug report output path"/>

      <StackPanel Orientation="Horizontal" Margin="0,16">
        <Button Content="Export .stackscope" Command="{Binding ExportCommand}" MinWidth="180"
                AutomationProperties.Name="Export bug report bundle"/>
        <Button Content="Open in Explorer" Command="{Binding OpenFolderCommand}" MinWidth="140"
                Margin="8,0"
                AutomationProperties.Name="Open bug report folder"/>
      </StackPanel>

      <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Muted}"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
