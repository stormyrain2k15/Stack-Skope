<UserControl x:Class="StackScope.Desktop.Views.CompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Surface.Panel}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Compare Transactions" Style="{StaticResource Text.Header}"
                   FontSize="{StaticResource Type.Display}" Margin="0,0,0,16"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Left transaction" Style="{StaticResource Text.Muted}"/>
                <TextBox Text="{Binding LeftTransactionId, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="Left transaction id"/>
            </StackPanel>
            <TextBlock Grid.Column="1" Text="  ↔  " VerticalAlignment="Bottom"
                       Style="{StaticResource Text.Muted}" Margin="16,0"/>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Right transaction" Style="{StaticResource Text.Muted}"/>
                <TextBox Text="{Binding RightTransactionId, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="Right transaction id"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Only in Left" Style="{StaticResource Text.Muted}"/>
                <TextBlock Text="{Binding OnlyInLeftCount, StringFormat={}{0:N0}}"
                           Style="{StaticResource Text.Body}"
                           FontSize="{StaticResource Type.Display}"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="In Both" Style="{StaticResource Text.Muted}"/>
                <TextBlock Text="{Binding InBothCount, StringFormat={}{0:N0}}"
                           Style="{StaticResource Text.Body}"
                           FontSize="{StaticResource Type.Display}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Only in Right" Style="{StaticResource Text.Muted}"/>
                <TextBlock Text="{Binding OnlyInRightCount, StringFormat={}{0:N0}}"
                           Style="{StaticResource Text.Body}"
                           FontSize="{StaticResource Type.Display}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
