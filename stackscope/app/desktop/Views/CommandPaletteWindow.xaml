<Window x:Class="StackScope.Desktop.Views.CommandPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Title="Command Palette"
        Height="360" Width="540"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.Surface.Panel}"
        Foreground="{StaticResource Brush.Text.Primary}">
    <DockPanel LastChildFill="True" Margin="12">
        <TextBox x:Name="Search" DockPanel.Dock="Top"
                 Padding="8,6" FontSize="14"
                 AutomationProperties.Name="Command search"
                 KeyDown="OnSearchKeyDown"
                 TextChanged="OnSearchChanged"/>
        <ListBox x:Name="Results" Margin="0,8,0,0"
                 AutomationProperties.Name="Command results"
                 MouseDoubleClick="OnActivate"
                 KeyDown="OnResultsKeyDown"
                 Background="{StaticResource Brush.Surface.Base}"
                 BorderBrush="{StaticResource Brush.Border.Subtle}"
                 Foreground="{StaticResource Brush.Text.Primary}"/>
    </DockPanel>
</Window>
