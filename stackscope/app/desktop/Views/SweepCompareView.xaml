<UserControl x:Class="StackScope.Desktop.Views.SweepCompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Surface.Panel}">
  <DockPanel Margin="12" LastChildFill="True">
    <TextBlock DockPanel.Dock="Top" Text="Sweep Compare"
               Style="{StaticResource Text.Header}"
               FontSize="{StaticResource Type.Display}" Margin="0,0,0,4"/>
    <TextBlock DockPanel.Dock="Top" Style="{StaticResource Text.Muted}"
               TextWrapping="Wrap" Margin="0,0,0,10"
               Text="Overlays the per-cell σ from two saved sweep result files (sweep-resume-*.json). Red = right sweep had a bigger shift, blue = left sweep had a bigger shift. Peak |Δ| answers 'is this head universal or specific?'"/>

    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
      <TextBlock Text="Left"  Style="{StaticResource Text.Muted}" VerticalAlignment="Center" Width="42"/>
      <ComboBox  Width="360" ItemsSource="{Binding AvailableSweeps}"
                 SelectedItem="{Binding LeftFile}"
                 AutomationProperties.Name="Left sweep file"/>
    </StackPanel>
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
      <TextBlock Text="Right" Style="{StaticResource Text.Muted}" VerticalAlignment="Center" Width="42"/>
      <ComboBox  Width="360" ItemsSource="{Binding AvailableSweeps}"
                 SelectedItem="{Binding RightFile}"
                 AutomationProperties.Name="Right sweep file"/>
      <Button    Content="Compare"       Command="{Binding LoadAndCompareCommand}"
                 Padding="14,4" Margin="12,0,0,0"
                 AutomationProperties.Name="Run sweep comparison"/>
      <Button    Content="Refresh list"  Command="{Binding RefreshAvailableCommand}"
                 Padding="10,4" Margin="6,0,0,0"
                 AutomationProperties.Name="Refresh available sweep files"/>
      <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Muted}"
                 VerticalAlignment="Center" Margin="16,0,0,0"
                 TextTrimming="CharacterEllipsis" MaxWidth="480"/>
    </StackPanel>

    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding Cells}"
                    AutomationProperties.Name="Sweep compare heatmap">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="{Binding DataContext.HeadCount,
                                   RelativeSource={RelativeSource AncestorType=UserControl}}"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Width="52" Height="34" Margin="1"
                    BorderThickness="1"
                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                    Background="{Binding Fill}"
                    ToolTip="{Binding Tooltip}">
              <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                         FontFamily="Consolas" Foreground="White" FontSize="10"
                         Text="{Binding Delta, StringFormat={}{0:+0.00;-0.00;0.00}}"/>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</UserControl>
