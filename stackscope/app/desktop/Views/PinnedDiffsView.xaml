<UserControl x:Class="StackScope.Desktop.Views.PinnedDiffsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Surface.Panel}">
  <DockPanel LastChildFill="True" Margin="12">

    <TextBlock DockPanel.Dock="Top" Text="Diff Pin Board" Style="{StaticResource Text.Header}"
               FontSize="{StaticResource Type.Display}" Margin="0,0,0,8"/>
    <TextBlock DockPanel.Dock="Top" Style="{StaticResource Text.Muted}"
               TextWrapping="Wrap"
               Text="Saved (baseline ⇆ candidate) diffs. Pin what Compare has loaded, add a note, and re-open it later to reseed CompareVm and re-run the diff. Persists in pinned_diffs.sqlite at the project root."/>

    <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1"
            BorderBrush="{StaticResource Brush.Border.Subtle}" Margin="0,10,0,6"/>

    <!-- Composer + action row -->
    <StackPanel DockPanel.Dock="Top" Orientation="Vertical" Margin="0,0,0,6">
      <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
        <TextBlock Text="Note"  Style="{StaticResource Text.Muted}"
                   VerticalAlignment="Center" Width="52"/>
        <TextBox   Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}"
                   Width="360" AutomationProperties.Name="Pin note"/>
        <TextBlock Text="Tags"  Style="{StaticResource Text.Muted}"
                   VerticalAlignment="Center" Margin="10,0,4,0"/>
        <TextBox   Text="{Binding NewTags, UpdateSourceTrigger=PropertyChanged}"
                   Width="180" AutomationProperties.Name="Pin tags"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal">
        <Button Content="Pin current"   Command="{Binding PinCurrentCommand}"
                MinWidth="120"
                ToolTip="Persist the pair currently loaded in Compare (L/R/σ) as a new pin."
                AutomationProperties.Name="Pin current diff"/>
        <Button Content="Open pin"      Command="{Binding OpenSelectedCommand}"
                MinWidth="90" Margin="8,0,0,0"
                ToolTip="Reload the selected pin into Compare and rerun."
                AutomationProperties.Name="Open selected pin"/>
        <Button Content="Save note"     Command="{Binding SaveSelectedNoteCommand}"
                MinWidth="90" Margin="6,0"
                AutomationProperties.Name="Save note on selected pin"/>
        <Button Content="Delete"        Command="{Binding DeleteSelectedCommand}"
                MinWidth="80"
                AutomationProperties.Name="Delete selected pin"/>
        <Button Content="Refresh"       Command="{Binding RefreshCommand}"
                MinWidth="80" Margin="6,0,0,0"
                AutomationProperties.Name="Refresh pin list"/>
        <TextBlock Text="{Binding Status}" Style="{StaticResource Text.Muted}"
                   VerticalAlignment="Center" Margin="16,0,0,0"
                   TextTrimming="CharacterEllipsis" MaxWidth="480"/>
      </StackPanel>
    </StackPanel>

    <ListView ItemsSource="{Binding Pins}"
              SelectedItem="{Binding Selected}"
              AutomationProperties.Name="Pinned diffs list">
      <ListView.View>
        <GridView>
          <GridViewColumn Header="#"      Width="50"  DisplayMemberBinding="{Binding Id}"/>
          <GridViewColumn Header="Left"   Width="180" DisplayMemberBinding="{Binding LeftTransactionId}"/>
          <GridViewColumn Header="Right"  Width="180" DisplayMemberBinding="{Binding RightTransactionId}"/>
          <GridViewColumn Header="σ"      Width="60">
            <GridViewColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Style="{StaticResource Text.Mono}"
                           Text="{Binding SigmaThreshold, StringFormat={}{0:F2}}"/>
              </DataTemplate>
            </GridViewColumn.CellTemplate>
          </GridViewColumn>
          <GridViewColumn Header="Note"   Width="320" DisplayMemberBinding="{Binding Note}"/>
          <GridViewColumn Header="Tags"   Width="140" DisplayMemberBinding="{Binding Tags}"/>
        </GridView>
      </ListView.View>
    </ListView>
  </DockPanel>
</UserControl>
